# --- DEPENDENCIES ---
# Matches node_modules in root and all subfolders (client/server)
node_modules/
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- TYPESCRIPT / BUILD OUTPUTS ---
# Ignore compiled javascript and build folders
dist/
build/
out/
bin/
obj/
*.tsbuildinfo
next-env.d.ts

# --- ENVIRONMENT / SECRETS ---
# NEVER commit these to GitHub
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.example
*.pem
*.crt

# --- DEBUG & LOGS ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs
*.log
firebase-debug.log
firestore-debug.log

# --- IDE & SYSTEM ---
.vscode/
.idea/
.DS_Store
Thumbs.db
.vercel
.genkit/

# --- TESTING ---
/coverage

# --- KUBERNETES ---
k8s/backend-secret.yaml
