# Backend Environment Variables Template
# Copy this content to .env.local and fill in actual values

# Server Configuration
# Node environment (development, staging, production)
NODE_ENV=development
# Server port
PORT=5000
# Server host (default: localhost)
HOST=localhost
# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:3002

# Database Configuration
# MongoDB connection string (Atlas format)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/makikibahay?retryWrites=true&w=majority
# Database name for main application
MONGODB_DB_NAME=makikibahay
# Database name for testing
MONGODB_TEST_NAME=makikibahay_test

# Authentication Configuration
# Secret key for JWT tokens (minimum 32 characters)
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
# Secret key for JWT refresh tokens (minimum 32 characters)
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_32_characters_long
# Expiration time for access tokens (format: 1h, 30m, 7d)
JWT_EXPIRES_IN=1h
# Expiration time for refresh tokens
JWT_REFRESH_EXPIRES_IN=7d

# Password Security
# Number of rounds for bcrypt hashing (recommended: 10-12)
BCRYPT_ROUNDS=12
# Minimum password length for users
PASSWORD_MIN_LENGTH=8

# OAuth Configuration (Google OAuth for social login)
# Google OAuth 2.0 Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id
# Google OAuth 2.0 Client Secret
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cloudinary Configuration (for file storage)
# Cloudinary Cloud Name
CLOUDINARY_CLOUD_NAME=your-cloud-name
# Cloudinary API Key
CLOUDINARY_API_KEY=your-api-key
# Cloudinary API Secret
CLOUDINARY_API_SECRET=your-api-secret

# Email Service Configuration
# SMTP server hostname
SMTP_HOST=smtp.gmail.com
# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587
# SMTP username (your email)
SMTP_USER=your_email@gmail.com
# SMTP password or app password
SMTP_PASS=your_app_password_here
# Default sender email address
EMAIL_FROM=noreply@makikibahay.com
# Default sender name
EMAIL_FROM_NAME=Makikibahay

# File Upload Configuration
# Local upload directory (when not using cloud storage)
UPLOAD_DIR=uploads
# Maximum file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760
# Comma-separated list of allowed MIME types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Redis Configuration (for caching and sessions)
# Redis connection URL
REDIS_URL=redis://localhost:6379
# Redis password (if required)
REDIS_PASSWORD=your_redis_password_here
# Default TTL for cached keys in seconds
REDIS_TTL=3600

# Rate Limiting
# Time window in milliseconds (15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
# Allowed origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3002
# Allow credentials in CORS requests
CORS_CREDENTIALS=true

# Logging Configuration
# Log level (error, warn, info, debug)
LOG_LEVEL=info
# Log file path
LOG_FILE=logs/app.log
# Maximum log file size with unit (10m, 1g)
LOG_MAX_SIZE=10m
# Maximum number of log files to keep
LOG_MAX_FILES=5

# Security Configuration
# Enable Helmet middleware for security headers
HELMET_ENABLED=true
# Secret key for session management
SESSION_SECRET=your_session_secret_minimum_32_characters
# Secret key for cookie signing
COOKIE_SECRET=your_cookie_secret_minimum_32_characters

# WebSocket Configuration
# Enable WebSocket support for real-time features
WS_ENABLED=true
# WebSocket server port
WS_PORT=5000
# WebSocket endpoint path
WS_PATH=/socket.io

# Development Settings
# Enable seed data population on startup
DEV_SEED_DATA=true
# Mock email sending during development
DEV_MOCK_EMAIL=true
# Skip email verification during development
DEV_SKIP_EMAIL_VERIFICATION=true