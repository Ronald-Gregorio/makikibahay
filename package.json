{
  "name": "makikibahay",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "start": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "db:setup": "cd apps/backend && npm run db:setup",
    "db:seed": "cd apps/backend && npm run db:seed",
    "deploy:frontend": "cd apps/frontend && npm run deploy",
    "deploy:backend": "cd apps/backend && npm run deploy",
    "docs:update": "node scripts/update-changelog.js"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "npm@10.0.0"
}